execute if score *glowing deathswap.setting matches 1 run item replace entity @a[tag=admin,tag=!creative,scores={deathswap.ui_page=1}] inventory.24 with potion[custom_data={ui:1b},custom_name={"text":"§aGlowing Effect: Enabled"},lore=['§7Whether to give players glowing Effect'],potion_contents={custom_color:16777215},tooltip_display={hidden_components:["potion_contents"]},enchantment_glint_override=true]

